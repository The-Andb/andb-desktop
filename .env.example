# TheAndb Desktop - Environment Variables Example
# Copy this file to .env and adjust values as needed.

# ========================================
# FEATURE FLAGS (true = Enabled, false = Disabled)
# ========================================
FEATURE_MCP_SERVER=true
FEATURE_GIT_SYNC=true
FEATURE_SCHEMA_REPORT=true
FEATURE_DRIFT_DETECTION=true
FEATURE_BETA_GATE=false
FEATURE_BUG_REPORT=false
FEATURE_FEATURE_SUGGEST=false
FEATURE_DB_DESIGNER=false
FEATURE_AUTO_BACKUP=false
FEATURE_FOCUS_MODE=true
FEATURE_ER_DIAGRAM=false
FEATURE_QUICK_DUMP=true
FEATURE_LIVE_DEMO=false
FEATURE_DOMAIN_LOGIC=false

