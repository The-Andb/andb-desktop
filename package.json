{
  "name": "@the-andb/desktop",
  "productName": "TheAndb",
  "version": "3.3.5",
  "private": true,
  "description": "TheAndb - Keep Going. Keep Syncing.",
  "main": "dist-electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc && vite build",
    "preview": "vite preview",
    "electron": "electron .",
    "build:electron": "node scripts/build-electron.mjs",
    "electron:dev": "pnpm run build:electron && NODE_ENV=development concurrently \"pnpm run dev\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "pnpm run build:electron && pnpm run build && electron-builder && node scripts/verify-build.mjs",
    "electron:publish": "pnpm run build:electron && pnpm run build && electron-builder --publish always -c.releaseInfo.releaseNotesFile=../andb-www/releases/v$npm_package_version.md && node scripts/verify-build.mjs",
    "test:prod": "pnpm run build:electron && pnpm run build && NODE_ENV=production npx electron .",
    "test:packaged": "open 'dist/TheAndb-3.0.0-arm64.dmg'",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --ignore-path .eslintignore",
    "lint:fix": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix --ignore-path .eslintignore",
    "format": "prettier --write \"src/**/*.{js,ts,vue,css,scss,json}\"",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "sample:load": "node scripts/load-sample-data.js",
    "rebuild": "electron-rebuild -f -w better-sqlite3",
    "postinstall": "pnpm run rebuild"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/The-Andb/andb-desktop.git"
  },
  "keywords": [
    "database",
    "migration",
    "mysql",
    "postgres",
    "electron",
    "vue",
    "andb-core"
  ],
  "author": "TheAndb Team",
  "license": "Proprietary",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/The-Andb/andb-desktop/issues"
  },
  "homepage": "https://github.com/The-Andb/andb-desktop#readme",
  "devDependencies": {
    "@headlessui/vue": "^1.7.23",
    "@modyfi/vite-plugin-yaml": "^1.1.1",
    "@playwright/test": "^1.58.0",
    "@sentry/electron": "^7.9.0",
    "@tailwindcss/typography": "^0.5.10",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/user-event": "^14.6.1",
    "@testing-library/vue": "^8.1.0",
    "@the-andb/core": "workspace:*",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.19.10",
    "@types/prismjs": "^1.26.5",
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.54.0",
    "@vitejs/plugin-vue": "^4.5.2",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "@vue/test-utils": "^2.4.6",
    "@vueuse/core": "^10.7.1",
    "andb-logger": "^1.0.3",
    "autoprefixer": "^10.4.23",
    "concurrently": "^9.2.1",
    "electron": "34.0.0",
    "electron-builder": "24.13.3",
    "electron-rebuild": "^3.2.9",
    "electron-reload": "^2.0.0-alpha.1",
    "electron-serve": "^1.1.0",
    "electron-store": "^8.2.0",
    "electron-updater": "^6.7.3",
    "esbuild": "^0.27.4",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-vue": "^10.7.0",
    "happy-dom": "^20.4.0",
    "highcharts": "^12.5.0",
    "highcharts-vue": "^2.0.1",
    "html-to-image": "^1.11.13",
    "js-yaml": "^4.1.1",
    "lucide-vue-next": "^0.294.0",
    "mysql2": "^3.16.2",
    "pinia": "^2.1.7",
    "playwright": "^1.58.0",
    "postcss": "^8.5.6",
    "posthog-js": "^1.358.1",
    "prebuild-install": "^7.1.2",
    "prettier": "^3.8.1",
    "prismjs": "^1.30.0",
    "splitpanes": "^4.0.4",
    "tailwindcss": "^3.4.0",
    "tailwindcss-animate": "^1.0.7",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "vite": "^5.0.8",
    "vitest": "^4.0.18",
    "vue": "^3.5.27",
    "vue-i18n": "^9.14.5",
    "vue-router": "^4.6.4",
    "vue-tsc": "^3.2.4",
    "vuedraggable": "^4.1.0",
    "wait-on": "^8.0.4"
  },
  "build": {
    "asar": true,
    "asarUnpack": [
      "**/node_modules/better-sqlite3/**/*"
    ],
    "appId": "com.anph.andb.v3",
    "productName": "TheAndb",
    "copyright": "Copyright © 2024 - 2026 TheAndb",
    "directories": {
      "output": "dist",
      "buildResources": "public"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "!dist-electron/main.ts",
      "package.json",
      "public/**/*",
      "!public/*.dmg",
      "!public/*.zip"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "public/icon.png",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "artifactName": "${productName}-${version}-${arch}.${ext}",
      "executableName": "theandb",
      "category": "Development",
      "maintainer": "TheAndb Team"
    },
    "deb": {
      "packageName": "theandb",
      "priority": "optional",
      "packageCategory": "devel"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "The-Andb",
        "repo": "andb-desktop"
      }
    ],
    "extraResources": [
      {
        "from": "../andb-cli",
        "to": "tools/andb-cli",
        "filter": [
          "dist/andb-cli-mac*",
          "package.json"
        ]
      },
      {
        "from": "../andb-mcp",
        "to": "tools/andb-mcp",
        "filter": [
          "dist/andb-mcp-mac*",
          "package.json"
        ]
      }
    ]
  },
  "dependencies": {
    "better-sqlite3": "^12.6.2",
    "bindings": "^1.5.0",
    "file-uri-to-path": "^2.0.0",
    "marked": "17.0.6",
    "reflect-metadata": "^0.2.2",
    "typeorm": "^0.3.28"
  }
}