{
  "name": "@the-andb/desktop",
  "productName": "The Andb",
  "version": "3.1.0-beta.2",
  "description": "The Andb - Simplest Database Migration Tool",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc && vite build",
    "preview": "vite preview",
    "electron": "electron .",
    "build:electron": "tsc -p tsconfig.electron.json",
    "electron:dev": "npm run build:electron && NODE_ENV=development concurrently \"npm run dev\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "npm run build && npm run build:electron && electron-builder",
    "electron:publish": "npm run build && npm run build:electron && electron-builder --publish always",
    "test:prod": "npm run build && npm run build:electron && NODE_ENV=production npx electron .",
    "test:packaged": "open 'dist/The Andb-3.0.0-arm64.dmg'",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --ignore-path .eslintignore",
    "lint:fix": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix --ignore-path .eslintignore",
    "format": "prettier --write \"src/**/*.{js,ts,vue,css,scss,json}\"",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test",
    "sample:load": "node scripts/load-sample-data.js",
    "rebuild": "electron-rebuild -f -w better-sqlite3",
    "postinstall": "npm run rebuild"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/The-Andb/andb-desktop.git"
  },
  "keywords": [
    "database",
    "migration",
    "mysql",
    "postgres",
    "electron",
    "vue",
    "andb-core"
  ],
  "author": "The Andb",
  "license": "Proprietary",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/The-Andb/andb-desktop/issues"
  },
  "homepage": "https://github.com/The-Andb/andb-desktop#readme",
  "devDependencies": {
    "@modyfi/vite-plugin-yaml": "^1.1.1",
    "@playwright/test": "^1.58.0",
    "@tailwindcss/typography": "^0.5.10",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/user-event": "^14.6.1",
    "@testing-library/vue": "^8.1.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.19.10",
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.54.0",
    "@vitejs/plugin-vue": "^4.5.2",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "autoprefixer": "^10.4.23",
    "concurrently": "^9.2.1",
    "electron": "34.0.0",
    "electron-builder": "24.13.3",
    "electron-rebuild": "^3.2.9",
    "electron-reload": "^2.0.0-alpha.1",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-vue": "^10.7.0",
    "happy-dom": "^20.4.0",
    "playwright": "^1.58.0",
    "postcss": "^8.5.6",
    "prettier": "^3.8.1",
    "tailwindcss": "^3.4.0",
    "tailwindcss-animate": "^1.0.7",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "vite": "^5.0.8",
    "vitest": "^4.0.18",
    "vue-tsc": "^3.2.4",
    "wait-on": "^8.0.4"
  },
  "build": {
    "asar": true,
    "asarUnpack": [
      "**/node_modules/better-sqlite3/**/*"
    ],
    "appId": "com.anph.andb.v3",
    "productName": "The Andb",
    "copyright": "Copyright © 2024 - 2026 The Andb",
    "directories": {
      "output": "dist",
      "buildResources": "public"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "!dist-electron/main.ts",
      "package.json",
      "public/**/*",
      "!public/*.dmg",
      "!public/*.zip",
      "!**/node_modules/*/{CHANGELOG.md,README.md,README,readme.md,readme}",
      "!**/node_modules/*/{test,__tests__,tests,powered-test,example,examples}",
      "!**/node_modules/.bin"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "public/icon.png",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "The-Andb",
        "repo": "andb-desktop"
      }
    ]
  },
  "dependencies": {
    "@headlessui/vue": "^1.7.23",
    "@sentry/electron": "^7.9.0",
    "@the-andb/core": "workspace:*",
    "@types/prismjs": "^1.26.5",
    "@vueuse/core": "^10.7.1",
    "andb-logger": "^1.0.3",
    "better-sqlite3": "^12.6.2",
    "electron-serve": "^1.1.0",
    "electron-store": "^8.2.0",
    "electron-updater": "^6.7.3",
    "highcharts": "^12.5.0",
    "highcharts-vue": "^2.0.1",
    "html-to-image": "^1.11.13",
    "lucide-vue-next": "^0.294.0",
    "mysql2": "^3.16.2",
    "pinia": "^2.1.7",
    "posthog-js": "^1.358.1",
    "prismjs": "^1.30.0",
    "vue": "^3.5.27",
    "vue-i18n": "^9.14.5",
    "vue-router": "^4.6.4",
    "vuedraggable": "^4.1.0"
  }
}